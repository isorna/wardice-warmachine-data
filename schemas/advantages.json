{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Advantages",
  "description": "Dictionary of game advantages keyed by advantage id.",
  "type": "object",
  "additionalProperties": {
    "type": "object",
    "properties": {
      "name": {
        "type": "string"
      },
      "rules": {
        "type": "string"
      },
      "icon": {
        "type": "string",
        "minLength": 1
      },
      "type": {
        "type": "string",
        "enum": [
          "model",
          "weapon"
        ]
      }
    },
    "required": [
      "name",
      "rules",
      "icon",
      "type"
    ],
    "additionalProperties": false
  }
}
