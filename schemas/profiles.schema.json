{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "profiles.schema.json",
  "title": "Profile Map Schema",
  "description": "Profiles are stored as maps in data/profiles/[faction].[army].profiles.json and exposed through /api/profiles?faction=:faction&army=:army.",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/definitions/profile"
  },
  "definitions": {
    "profile": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "faction": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "points": {
          "type": "number"
        },
        "keywords": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "armies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fieldAllowance": {
          "type": "string"
        },
        "baseSize": {
          "type": "number",
          "enum": [
            30,
            40,
            50,
            80,
            120
          ]
        },
        "statistics": {
          "type": "object",
          "additionalProperties": {
            "oneOf": [
              {
                "type": "number"
              },
              {
                "$ref": "#/definitions/healthGrid"
              },
              {
                "type": "object"
              }
            ]
          },
          "properties": {
            "speed": {
              "type": "number"
            },
            "arcaneAttack": {
              "type": "number"
            },
            "arcana": {
              "type": "number"
            },
            "meleeAttack": {
              "type": "number"
            },
            "rangedAttack": {
              "type": "number"
            },
            "defense": {
              "type": "number"
            },
            "armour": {
              "type": "number"
            },
            "controlRange": {
              "type": "number"
            },
            "fury": {
              "type": "number"
            },
            "threshold": {
              "type": "number"
            },
            "health": {
              "oneOf": [
                {
                  "type": "number"
                },
                {
                  "$ref": "#/definitions/healthGrid"
                }
              ]
            }
          }
        },
        "advantages": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 2
              }
            ]
          }
        },
        "abilities": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 2
              }
            ]
          }
        },
        "spells": {
          "type": "array",
          "items": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 2
              }
            ]
          }
        },
        "feat": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "name": {
              "type": "string"
            },
            "rules": {
              "type": "string"
            }
          }
        },
        "animus": {
          "type": "string"
        },
        "weapons": {
          "type": "object",
          "additionalProperties": true
        },
        "grunts": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "models": {
          "oneOf": [
            {
              "type": "number"
            },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "profiles": {
          "type": "object",
          "additionalProperties": true
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "healthGrid": {
      "type": "object",
      "required": [
        "total",
        "grid"
      ],
      "additionalProperties": true,
      "properties": {
        "total": {
          "type": "number"
        },
        "grid": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "columns": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/damageColumn"
              }
            }
          }
        }
      }
    },
    "damageColumn": {
      "type": "object",
      "required": [
        "boxes"
      ],
      "additionalProperties": false,
      "properties": {
        "boxes": {
          "type": "number"
        },
        "systems": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    }
  }
}
