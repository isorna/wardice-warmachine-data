{
  "$id": "https://spec-kit.local/schemas/spell.json",
  "type": "object",
  "required": ["id", "name", "description"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-zA-Z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "faction": { "type": "string" },
    "cost": { "type": "number" },
    "range": { "type": "string" },
    "pow": { "type": "string" },
    "aoe": { "type": "string" },
    "duration": { "type": "string" },
    "effect": { "type": "string" },
    "notes": { "type": "string" }
  }
}
