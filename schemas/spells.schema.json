{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "spells.schema.json",
  "title": "Spells",
  "description": "Schema for mk4/spells/spells.json map entries.",
  "type": "object",
  "additionalProperties": {
    "$ref": "#/definitions/spell"
  },
  "definitions": {
    "spell": {
      "type": "object",
      "required": ["name", "description", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["spell", "animus"]
        },
        "faction": {
          "type": "string"
        },
        "cost": {
          "type": "number"
        },
        "range": {
          "type": "string"
        },
        "pow": {
          "type": "string"
        },
        "aoe": {
          "type": "string"
        },
        "duration": {
          "type": "string"
        },
        "effect": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
